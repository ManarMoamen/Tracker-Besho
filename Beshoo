<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Evolution Elite Tracker</title>
    
    <script>
        // Your brand new Supabase credentials!
        const SUPABASE_URL = 'https://nyrbhinmvwfgmwttzwlh.supabase.co'; 
        const SUPABASE_KEY = 'Sb_publishable_bNCEdxByRj2ZQbXVPF1haw_R8FuW03Y';
    </script>

    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        :root { --bg: #050505; --card: #111; --purple: #a855f7; --text: #fff; --dim: #666; --green: #4ade80; --red: #fb7185; --blue: #3b82f6; }
        body { background: var(--bg); color: var(--text); font-family: 'Segoe UI', sans-serif; margin: 0; padding-bottom: 50px; }
        .container { max-width: 900px; margin: auto; padding: 20px; }
        
        /* Tabs */
        .tabs { display: flex; justify-content: center; gap: 20px; margin-bottom: 30px; position: sticky; top: 0; background: var(--bg); padding: 15px; z-index: 100; border-bottom: 1px solid #222; }
        .tab-btn { background: none; border: none; color: var(--dim); font-size: 16px; font-weight: bold; cursor: pointer; padding: 10px 20px; transition: 0.3s; }
        .tab-btn.active { color: var(--purple); border-bottom: 3px solid var(--purple); }
        .hidden { display: none; }

        .card { background: var(--card); border-radius: 20px; padding: 25px; margin-bottom: 20px; border: 1px solid #222; }
        h3 { color: var(--purple); font-size: 14px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px; display: flex; justify-content: space-between; align-items: center;}
        .subtitle { font-size: 11px; color: var(--dim); margin-top: -10px; margin-bottom: 15px; display: block; }
        
        .nav-btn { background: #1a1a1a; border: 1px solid #333; color: var(--dim); padding: 8px 15px; border-radius: 8px; cursor: pointer; white-space: nowrap; font-weight: bold; margin: 2px; font-size: 12px; transition: 0.3s; }
        .nav-btn.active { background: var(--purple); color: white; border-color: var(--purple); }
        
        .muscle-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap: 10px; margin-bottom: 15px; }
        .chip { background: #1a1a1a; border: 1px solid #333; padding: 12px; border-radius: 12px; display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 13px; transition: 0.3s; }
        .chip:hover { border-color: var(--purple); }
        input[type="checkbox"] { accent-color: var(--purple); width: 16px; height: 16px; }

        input[type="number"], input[type="text"] { background: #1a1a1a; border: 1px solid #333; color: white; padding: 15px; width: 100%; border-radius: 12px; margin-bottom: 10px; box-sizing: border-box; }
        .save-btn { background: var(--purple); color: white; border: none; padding: 18px; width: 100%; border-radius: 15px; font-weight: bold; cursor: pointer; font-size: 16px; letter-spacing: 1px; transition: 0.3s; }
        .save-btn:hover { background: #9333ea; }
        
        /* Dashboard Stats */
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 12px; }
        .stat-box { background: #1a1a1a; padding: 15px; border-radius: 15px; text-align: center; border: 1px solid #222; }
        .stat-val { font-size: 22px; font-weight: bold; display: block; color: var(--purple); }
        .stat-label { font-size: 9px; color: var(--dim); text-transform: uppercase; margin-top: 4px; display: block;}
        
        /* Goal progress bars */
        .progress-container { width: 100%; background: #222; border-radius: 10px; margin-top: 8px; overflow: hidden; height: 8px; }
        .progress-bar { height: 100%; background: var(--purple); transition: width 0.5s ease; }
    </style>
</head>
<body>

<div class="tabs">
    <button class="tab-btn active" id="logTab" onclick="showTab('logger')">LOG DATA</button>
    <button class="tab-btn" id="dashTab" onclick="showTab('dashboard')">DASHBOARD</button>
</div>

<div class="container">
    <div id="logger">
        <div class="card">
            <h3>Timeline Selection</h3>
            <div id="pNav" style="overflow-x:auto; display:flex; gap:5px; padding-bottom:10px;"></div>
            <div id="dNav" style="overflow-x:auto; display:flex; gap:5px;"></div>
        </div>

        <div class="card">
            <h3>Metrics & Fuel</h3>
            <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px;">
                <input type="number" id="wAM" placeholder="Weight Morning (kg)" step="0.1">
                <input type="number" id="prot" placeholder="Protein (g)">
            </div>
            <input type="number" id="wat" placeholder="Water (L)" step="0.5">
        </div>

        <div class="card">
            <h3>Calorie Deficit Tracker</h3>
            <span class="subtitle">Goal: 1920 kcal/day (1.5 - 2kg loss per Round)</span>
            <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px;">
                <input type="number" id="foodDef" placeholder="Diet Deficit (Goal: 1250)">
                <input type="number" id="exBurn" placeholder="Cardio/Gym Burn (Goal: 670)">
            </div>
        </div>

        <div class="card">
            <h3>Workout & Muscles</h3>
            <div class="muscle-grid">
                <label class="chip"><input type="checkbox" name="m" value="Back"> Back</label>
                <label class="chip"><input type="checkbox" name="m" value="Chest"> Chest</label>
                <label class="chip"><input type="checkbox" name="m" value="Legs"> Legs</label>
                <label class="chip"><input type="checkbox" name="m" value="Shoulders"> Shoulders</label>
                <label class="chip"><input type="checkbox" name="m" value="Arms"> Arms</label>
            </div>
            <input type="text" id="ex" placeholder="Exercise Details (Weights, Reps, etc.)">
        </div>

        <div class="card">
            <h3>Daily Habits Checklist</h3>
            <div class="muscle-grid">
                <label class="chip"><input type="checkbox" id="checkCreatine"> Creatine</label>
                <label class="chip"><input type="checkbox" id="checkVitamins"> Vitamins</label>
                <label class="chip"><input type="checkbox" id="checkSleep"> 7.5h Sleep</label>
                <label class="chip"><input type="checkbox" id="checkLowCarb"> Low Carb</label>
            </div>
            <button class="save-btn" onclick="save()" style="margin-top: 15px;">SYNC TO CLOUD ☁️</button>
            <div id="status" style="text-align:center; margin-top:10px; color:var(--purple); font-size:12px; font-weight:bold;">Ready</div>
        </div>
    </div>

    <div id="dashboard" class="hidden">
        
        <div class="stats-grid" id="mainStats" style="margin-bottom: 20px;">
            <div class="stat-box"><span class="stat-val" id="stat-weight">0</span><span class="stat-label">Total Loss (kg)</span></div>
            <div class="stat-box"><span class="stat-val" id="stat-protein">0%</span><span class="stat-label">Protein Hit</span></div>
            <div class="stat-box"><span class="stat-val" id="stat-habit">0%</span><span class="stat-label">Habits</span></div>
            <div class="stat-box"><span class="stat-val" id="stat-days">0/80</span><span class="stat-label">Progress</span></div>
        </div>

        <div class="card">
            <h3>Current Round Targets <span>(Phase <span id="dashPhaseNum">1</span>)</span></h3>
            <div class="stats-grid">
                <div class="stat-box">
                    <span class="stat-val" id="phase-weight-loss">0 kg</span>
                    <span class="stat-label">Round Loss (Goal: 1.5 - 2kg)</span>
                </div>
                <div class="stat-box">
                    <span class="stat-val" id="phase-avg-deficit">0 kcal</span>
                    <span class="stat-label">Avg Daily Deficit (Goal: 1920)</span>
                </div>
            </div>
        </div>

        <div class="card">
            <h3>Round Weight Trend</h3>
            <span class="subtitle">Daily fluctuations for current phase</span>
            <div id="weightTrend" style="display:flex; justify-content:space-between; align-items:flex-end; height:120px; padding-top:20px; border-bottom:1px solid #333; gap:5px;">
                </div>
            <div id="weightLabels" style="display:flex; justify-content:space-between; margin-top:10px; font-size:10px; color:var(--dim);">
                </div>
        </div>

        <div class="card">
            <h3>Muscle Hits (Current Round)</h3>
            <span class="subtitle">Goal: Hit every muscle 2x per round</span>
            <div id="muscleTally" style="display:grid; grid-template-columns: 1fr 1fr; gap:15px;"></div>
        </div>

        <div class="card">
            <h3>Evolution Progress Map</h3>
            <div id="dayMap" style="display:grid; grid-template-columns:repeat(8, 1fr); gap:5px; margin-top:10px;"></div>
        </div>
    </div>
</div>

<script>
    const supabaseClient = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
    let currP = 1, currD = 1;

    async function save() {
        document.getElementById('status').innerText = "Syncing with Cloud...";
        const muscles = Array.from(document.querySelectorAll('input[name="m"]:checked')).map(c => c.value);
        
        const payload = {
            day_key: `p${currP}d${currD}`,
            w_am: document.getElementById('wAM').value || null,
            muscles: muscles,
            exercise: document.getElementById('ex').value,
            protein: document.getElementById('prot').value || 0,
            water: document.getElementById('wat').value || 0,
            creatine: document.getElementById('checkCreatine').checked,
            vitamins: document.getElementById('checkVitamins').checked,
            sleep: document.getElementById('checkSleep').checked,
            lowcarb: document.getElementById('checkLowCarb').checked,
            food_deficit: document.getElementById('foodDef').value || 0,
            exercise_burn: document.getElementById('exBurn').value || 0
        };

        const { error } = await supabaseClient.from('fitness_logs').upsert(payload, { onConflict: 'day_key' });
        document.getElementById('status').innerText = error ? "Error: " + error.message : "Updated Cloud! ✅";
        
        if (!document.getElementById('dashboard').classList.contains('hidden')) {
            renderDashboard();
        }
    }

    async function load() {
        const { data } = await supabaseClient.from('fitness_logs').select('*').eq('day_key', `p${currP}d${currD}`).single();
        if (data) {
            document.getElementById('wAM').value = data.w_am || '';
            document.getElementById('ex').value = data.exercise || '';
            document.getElementById('prot').value = data.protein || '';
            document.getElementById('wat').value = data.water || '';
            document.getElementById('foodDef').value = data.food_deficit || '';
            document.getElementById('exBurn').value = data.exercise_burn || '';
            document.getElementById('checkCreatine').checked = data.creatine || false;
            document.getElementById('checkVitamins').checked = data.vitamins || false;
            document.getElementById('checkSleep').checked = data.sleep || false;
            document.getElementById('checkLowCarb').checked = data.lowcarb || false;
            document.querySelectorAll('input[name="m"]').forEach(c => c.checked = (data.muscles || []).includes(c.value));
        } else {
            resetUI();
        }
    }

    function resetUI() {
        document.querySelectorAll('input[type="number"], input[type="text"]').forEach(i => i.value = '');
        document.querySelectorAll('input[type="checkbox"]').forEach(c => c.checked = false);
    }

    async function renderDashboard() {
        const { data, error } = await supabaseClient.from('fitness_logs').select('*');
        if (!data) return;

        document.getElementById('dashPhaseNum').innerText = currP;
        let currentPhaseData = data.filter(v => v.day_key.startsWith(`p${currP}`));

        // 1. Current Phase Targets Logic
        let phaseWeightsRaw = [];
        for(let i=1; i<=8; i++) {
            let d = currentPhaseData.find(x => x.day_key === `p${currP}d${i}`);
            phaseWeightsRaw.push(d && d.w_am ? parseFloat(d.w_am) : 0);
        }
        
        let validPhaseWeights = phaseWeightsRaw.filter(v => !isNaN(v) && v > 0);
        if (validPhaseWeights.length > 1) {
            let loss = (validPhaseWeights[0] - validPhaseWeights[validPhaseWeights.length - 1]).toFixed(1);
            let lossEl = document.getElementById('phase-weight-loss');
            lossEl.innerText = loss + ' kg';
            lossEl.style.color = loss >= 1.5 ? 'var(--green)' : 'var(--purple)';
        } else {
            document.getElementById('phase-weight-loss').innerText = '0 kg';
            document.getElementById('phase-weight-loss').style.color = 'var(--purple)';
        }

        let totalDeficit = 0, daysWithDeficitLogs = 0;
        currentPhaseData.forEach(day => {
            let foodDef = parseFloat(day.food_deficit) || 0;
            let exBurn = parseFloat(day.exercise_burn) || 0;
            if (foodDef > 0 || exBurn > 0) {
                totalDeficit += (foodDef + exBurn);
                daysWithDeficitLogs++;
            }
        });
        
        let avgDeficit = daysWithDeficitLogs > 0 ? Math.round(totalDeficit / daysWithDeficitLogs) : 0;
        let defEl = document.getElementById('phase-avg-deficit');
        defEl.innerText = avgDeficit + ' kcal';
        defEl.style.color = avgDeficit >= 1920 ? 'var(--green)' : 'var(--purple)';

        // 2. Weight Trend Mini-Chart
        const trendContainer = document.getElementById('weightTrend');
        const labelContainer = document.getElementById('weightLabels');
        trendContainer.innerHTML = ''; labelContainer.innerHTML = '';
        
        let minW = validPhaseWeights.length ? Math.min(...validPhaseWeights) - 1 : 0; 
        let maxW = validPhaseWeights.length ? Math.max(...validPhaseWeights) + 1 : 100;

        for(let i=0; i<8; i++) {
            let w = phaseWeightsRaw[i];
            let heightPct = w > 0 ? ((w - minW) / (maxW - minW)) * 100 : 0;
            if(heightPct > 100) heightPct = 100; if(heightPct < 5 && w > 0) heightPct = 10;

            trendContainer.innerHTML += `
                <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:flex-end;">
                    <span style="font-size:10px; color:var(--purple); margin-bottom:5px;">${w > 0 ? w : '-'}</span>
                    <div style="width:100%; max-width:24px; background:${w > 0 ? 'var(--purple)' : '#222'}; height:${w > 0 ? heightPct : 0}%; border-radius:4px 4px 0 0; transition:0.5s;"></div>
                </div>`;
            labelContainer.innerHTML += `<div style="flex:1; text-align:center;">D${i+1}</div>`;
        }

        // 3. Muscle Progress Bars
        let tally = {};
        currentPhaseData.forEach(v => {
            (v.muscles || []).forEach(m => tally[m] = (tally[m] || 0) + 1);
        });
        
        const mTally = document.getElementById('muscleTally');
        mTally.innerHTML = '';
        ['Back','Chest','Legs','Shoulders','Arms'].forEach(m => {
            let count = tally[m] || 0;
            let percent = Math.min((count / 2) * 100, 100);
            let color = count >= 2 ? 'var(--green)' : 'var(--purple)';
            mTally.innerHTML += `
            <div style="background:#1a1a1a; padding:15px; border-radius:15px; border:1px solid #222;">
                <div style="display:flex; justify-content:space-between; font-size:13px; margin-bottom:8px; font-weight:bold;">
                    <span>${m}</span>
                    <span style="color:${color}">${count}/2</span>
                </div>
                <div class="progress-container">
                    <div class="progress-bar" style="width:${percent}%; background:${color};"></div>
                </div>
            </div>`;
        });

        // 4. Lifetime Overview Stats
        document.getElementById('stat-days').innerText = `${data.length}/80`;
        let allWeights = data.map(v => parseFloat(v.w_am)).filter(v => !isNaN(v) && v > 0);
        document.getElementById('stat-weight').innerText = allWeights.length > 1 ? (allWeights[0] - allWeights[allWeights.length-1]).toFixed(1) : '0';

        let protHit = data.filter(v => parseInt(v.protein) >= 170).length;
        document.getElementById('stat-protein').innerText = data.length > 0 ? Math.round((protHit/data.length)*100) + '%' : '0%';

        let habitScore = data.reduce((acc, curr) => acc + (curr.creatine ? 1 : 0) + (curr.vitamins ? 1 : 0) + (curr.sleep ? 1 : 0) + (curr.lowcarb ? 1 : 0), 0);
        document.getElementById('stat-habit').innerText = (data.length * 4) > 0 ? Math.round((habitScore/(data.length * 4))*100) + '%' : '0%';

        // 5. Day Map Logic
        const map = document.getElementById('dayMap');
        map.innerHTML = '';
        let keys = data.map(v => v.day_key);
        for(let i=1; i<=80; i++) {
            let pIdx = Math.ceil(i/8), dIdx = i%8 || 8;
            let active = keys.includes(`p${pIdx}d${dIdx}`) ? 'filled' : '';
            map.innerHTML += `<div style="aspect-ratio:1; background:${active ? 'var(--purple)':'#222'}; border-radius:4px; font-size:8px; display:flex; align-items:center; justify-content:center; color:${active?'#fff':'#444'}">${i}</div>`;
        }
    }

    function showTab(t) {
        document.getElementById('logger').classList.toggle('hidden', t !== 'logger');
        document.getElementById('dashboard').classList.toggle('hidden', t !== 'dashboard');
        document.getElementById('logTab').classList.toggle('active', t === 'logger');
        document.getElementById('dashTab').classList.toggle('active', t === 'dashboard');
        if (t === 'dashboard') renderDashboard();
    }

    function init() {
        const pNav = document.getElementById('pNav');
        const dNav = document.getElementById('dNav');
        for(let i=1; i<=10; i++) pNav.innerHTML += `<button class="nav-btn" id="pb${i}" onclick="setP(${i})">Phase ${i}</button>`;
        for(let i=1; i<=8; i++) dNav.innerHTML += `<button class="nav-btn" id="db${i}" onclick="setD(${i})">Day ${i}</button>`;
        setP(1); setD(1);
    }
    
    function setP(v) { currP = v; updateUI('pb', 10, v); load(); if(!document.getElementById('dashboard').classList.contains('hidden')) renderDashboard(); }
    function setD(v) { currD = v; updateUI('db', 8, v); load(); }
    
    function updateUI(pre, count, active) {
        for(let i=1; i<=count; i++) {
            let el = document.getElementById(pre+i);
            if(el) el.className = (i===active ? 'nav-btn active' : 'nav-btn');
        }
    }
    window.onload = init;
</script>
</body>
</html>
